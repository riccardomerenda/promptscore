{
  "name": "promptscore-monorepo",
  "version": "0.4.8",
  "private": true,
  "description": "Static analysis for LLM prompts — ESLint, but for prompts.",
  "license": "MIT",
  "author": "Riccardo Merenda",
  "homepage": "https://promptscore.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/riccardomerenda/promptscore.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:web:static": "turbo run build --filter=@promptscore/web",
    "benchmark:llm": "npm --workspace @promptscore/core run benchmark:llm",
    "check:docs-sync": "node scripts/sync-product-docs.mjs --check",
    "check:live-site": "node scripts/check-live-site.mjs --version-path / --path /docs/",
    "changeset": "changeset",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release:publish": "npm run build && changeset publish",
    "sync:docs": "node scripts/sync-product-docs.mjs",
    "sync-release-version": "node scripts/sync-release-version.mjs",
    "version-packages": "changeset version && npm run sync-release-version && npm run sync:docs && npm install --package-lock-only --ignore-scripts",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "packageManager": "npm@11.0.0"
}
