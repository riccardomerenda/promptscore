{
  "name": "@promptscore/core",
  "version": "0.4.6",
  "description": "Static analysis for LLM prompts. Core library.",
  "license": "MIT",
  "author": "Riccardo Merenda",
  "homepage": "https://promptscore.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/riccardomerenda/promptscore.git",
    "directory": "packages/core"
  },
  "keywords": [
    "llm",
    "prompt",
    "prompt-engineering",
    "linter",
    "static-analysis",
    "claude",
    "gpt"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "benchmark:llm": "vitest run src/rules/llm/prompt-review.benchmark.test.ts --reporter verbose",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
